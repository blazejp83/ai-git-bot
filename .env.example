# Database (SQLite for dev, PostgreSQL connection string for production)
DATABASE_URL=sqlite://data/aigitbot.db

# Encryption key for API keys/tokens (required for production)
APP_ENCRYPTION_KEY=change-me-to-a-random-string

# Session secret for admin cookies
SESSION_SECRET=change-me-to-a-random-string

# Server port
PORT=8080

# Prompts directory
PROMPTS_DIR=prompts

# Agent settings
AGENT_ENABLED=true
AGENT_MAX_FILES=20
AGENT_MAX_TOKENS=32768
AGENT_BRANCH_PREFIX=ai-agent/
AGENT_MAX_FILE_CONTENT_CHARS=100000
AGENT_VALIDATION_ENABLED=true
AGENT_VALIDATION_MAX_RETRIES=3
